gt;\r","\t\t\u0026gt;\r","\t\t[\u0026quot;fr\u0026quot;] = \u0026lt;\r","\t\t\titems = \u0026lt;\r","\t\t\t\t[\u0026quot;at0000\u0026quot;] = \u0026lt;\r","\t\t\t\t\ttext = \u0026lt;\u0026quot;Données auto-déclarées\u0026quot;\u0026gt;\r","\t\t\t\t\tdescription = \u0026lt;\u0026quot;Conteneur générique pour des informations fournies par un individu.\u0026quot;\u0026gt;\r","\t\t\t\t\u0026gt;\r","\t\t\t\t[\u0026quot;at0003\u0026quot;] = \u0026lt;\r","\t\t\t\t\ttext = \u0026lt;\u0026quot;Item tree\u0026quot;\u0026gt;\r","\t\t\t\t\tdescription = \u0026lt;\u0026quot;@ internal @\u0026quot;\u0026gt;\r","\t\t\t\t\u0026gt;\r","\t\t\t\t[\u0026quot;at0004\u0026quot;] = \u0026lt;\r","\t\t\t\t\ttext = \u0026lt;\u0026quot;Extension\u0026quot;\u0026gt;\r","\t\t\t\t\tdescription = \u0026lt;\u0026quot;Informations supplémentaires requises pour la collecte locale du contenu ou pour l\u0026#39;alignement avec d\u0026#39;autres référentiels ou formalismes.\u0026quot;\u0026gt;\r","\t\t\t\t\tcomment = \u0026lt;\u0026quot;Par exemple: exigences locales d\u0026#39;informations ou méta-données supplémentaires pour l\u0026#39;alignement avec FHIR.\u0026quot;\u0026gt;\r","\t\t\t\t\u0026gt;\r","\t\t\t\t[\u0026quot;at0005\u0026quot;] = \u0026lt;\r","\t\t\t\t\ttext = \u0026lt;\u0026quot;Appareil\u0026quot;\u0026gt;\r","\t\t\t\t\tdescription = \u0026lt;\u0026quot;Appareil utilisé pour la collecte des données.\u0026quot;\u0026gt;\r","\t\t\t\t\u0026gt;\r","\t\t\t\t[\u0026quot;at0006\u0026quot;] = \u0026lt;\r","\t\t\t\t\ttext = \u0026lt;\u0026quot;Source de l\u0026#39;information\u0026quot;\u0026gt;\r","\t\t\t\t\tdescription = \u0026lt;\u0026quot;A propos d\u0026#39;un ou plusieurs types de sources pour les informations contenues dans le rapport.\u0026quot;\u0026gt;\r","\t\t\t\t\tcomment = \u0026lt;\u0026quot;Ces éléments de données peuvent être utilisées lorsque la source d\u0026#39;information est différente de l\u0026#39;auteur ou du rédacteur. Par exemple: \u0026#39;parent\u0026#39; ou \u0026#39;soignant\u0026#39;.\u0026quot;\u0026gt;\r","\t\t\t\t\u0026gt;\r","\t\t\t\u0026gt;\r","\t\t\u0026gt;\r","\t\t[\u0026quot;pt\u0026quot;] = \u0026lt;\r","\t\t\titems = \u0026lt;\r","\t\t\t\t[\u0026quot;at0000\u0026quot;] = \u0026lt;\r","\t\t\t\t\ttext = \u0026lt;\u0026quot;Dados auto-relatados\u0026quot;\u0026gt;\r","\t\t\t\t\tdescription = \u0026lt;\u0026quot;Contentor genérico para informação fornecida por um indivíduo.\u0026quot;\u0026gt;\r","\t\t\t\t\u0026gt;\r","\t\t\t\t[\u0026quot;at0003\u0026quot;] = \u0026lt;\r","\t\t\t\t\ttext = \u0026lt;\u0026quot;Item tree\u0026quot;\u0026gt;\r","\t\t\t\t\tdescription = \u0026lt;\u0026quot;@ internal @\u0026quot;\u0026gt;\r","\t\t\t\t\u0026gt;\r","\t\t\t\t[\u0026quot;at0004\u0026quot;] = \u0026lt;\r","\t\t\t\t\ttext = \u0026lt;\u0026quot;Extensão\u0026quot;\u0026gt;\r","\t\t\t\t\tdescription = \u0026lt;\u0026quot;Informação adicional necessária para captar conteúdos locais ou para alinhar com outros modelos/formalismos de referência.\u0026quot;\u0026gt;\r","\t\t\t\t\tcomment = \u0026lt;\u0026quot;Por exemplo: requisitos de informação local ou metadados adicionais para alinhar com FHIR.\u0026quot;\u0026gt;\r","\t\t\t\t\u0026gt;\r","\t\t\t\t[\u0026quot;at0005\u0026quot;] = \u0026lt;\r","\t\t\t\t\ttext = \u0026lt;\u0026quot;Dispositivo\u0026quot;\u0026gt;\r","\t\t\t\t\tdescription = \u0026lt;\u0026quot;Para capturar o dispositivo utilizado para reportar dados.\u0026quot;\u0026gt;\r","\t\t\t\t\u0026gt;\r","\t\t\t\t[\u0026quot;at0006\u0026quot;] = \u0026lt;\r","\t\t\t\t\ttext = \u0026lt;\u0026quot;Fonte de informação\u0026quot;\u0026gt;\r","\t\t\t\t\tdescription = \u0026lt;\u0026quot;Sobre um ou mais tipos de fontes para a informação contida no relatório.\u0026quot;\u0026gt;\r","\t\t\t\t\tcomment = \u0026lt;\u0026quot;Este elemento de dados pode ser utilizado quando a fonte de informação é diferente da do autor ou compositor. Por exemplo: \u0026#39;progenitor\u0026#39;; ou \u0026#39;cuidador\u0026#39;.\u0026quot;\u0026gt;\r","\t\t\t\t\u0026gt;\r","\t\t\t\u0026gt;\r","\t\t\u0026gt;\r","\t\t[\u0026quot;fi\u0026quot;] = \u0026lt;\r","\t\t\titems = \u0026lt;\r","\t\t\t\t[\u0026quot;at0000\u0026quot;] = \u0026lt;\r","\t\t\t\t\ttext = \u0026lt;\u0026quot;Itse ilmoitetut tiedot\u0026quot;\u0026gt;\r","\t\t\t\t\tdescription = \u0026lt;\u0026quot;Geneerinen säiliö henkilön itse ilmoittamille tiedoille.\u0026quot;\u0026gt;\r","\t\t\t\t\u0026gt;\r","\t\t\t\t[\u0026quot;at0003\u0026quot;] = \u0026lt;\r","\t\t\t\t\ttext = \u0026lt;\u0026quot;Item tree\u0026quot;\u0026gt;\r","\t\t\t\t\tdescription = \u0026lt;\u0026quot;@ internal @\u0026quot;\u0026gt;\r","\t\t\t\t\u0026gt;\r","\t\t\t\t[\u0026quot;at0004\u0026quot;] = \u0026lt;\r","\t\t\t\t\ttext = \u0026lt;\u0026quot;Laajennus\u0026quot;\u0026gt;\r","\t\t\t\t\tdescription = \u0026lt;\u0026quot;Lisätiedot, joita tarvitaan paikallisen asiayhteyden kirjaamiseksi tai yhtenäistämiseksi muiden viitemallien tai formalismien kanssa.\u0026quot;\u0026gt;\r","\t\t\t\t\tcomment = \u0026lt;\u0026quot;Esimerkiksi: paikalliset tietovaatimukset tai FHIR:n mukaiset metatiedot.\u0026quot;\u0026gt;\r","\t\t\t\t\u0026gt;\r","\t\t\t\t[\u0026quot;at0005\u0026quot;] = \u0026lt;\r","\t\t\t\t\ttext = \u0026lt;\u0026quot;Laite\u0026quot;\u0026gt;\r","\t\t\t\t\tdescription = \u0026lt;\u0026quot;Tietojen raportointiin käytetty laite.\u0026quot;\u0026gt;\r","\t\t\t\t\u0026gt;\r","\t\t\t\t[\u0026quot;at0006\u0026quot;] = \u0026lt;\r","\t\t\t\t\ttext = \u0026lt;\u0026quot;Tietolähde\u0026quot;\u0026gt;\r","\t\t\t\t\tdescription = \u0026lt;\u0026quot;Tietoja yhdestä tai useammasta raportin sisältämien tietojen lähdetyypeistä.\u0026quot;\u0026gt;\r","\t\t\t\t\tcomment = \u0026lt;\u0026quot;Tätä tietoelementtiä voidaan käyttää, kun tietolähde on eri kuin tiedon kirjaaja. Esimerkiksi: \u0026#39;vanhempi\u0026#39;; tai \u0026#39;hoitaja\u0026#39;.\u0026quot;\u0026gt;\r","\t\t\t\t\u0026gt;\r","\t\t\t\u0026gt;\r","\t\t\u0026gt;\r","\t\t[\u0026quot;zh-cn\u0026quot;] = \u0026lt;\r","\t\t\titems = \u0026lt;\r","\t\t\t\t[\u0026quot;at0000\u0026quot;] = \u0026lt;\r","\t\t\t\t\ttext = \u0026lt;\u0026quot;自行报告的数据\u0026quot;\u0026gt;\r","\t\t\t\t\tdescription = \u0026lt;\u0026quot;针对个人所提供信息的容器。又可称为“自我报告的数据”\u0026quot;\u0026gt;\r","\t\t\t\t\u0026gt;\r","\t\t\t\t[\u0026quot;at0003\u0026quot;] = \u0026lt;\r","\t\t\t\t\ttext = \u0026lt;\u0026quot;Item tree\u0026quot;\u0026gt;\r","\t\t\t\t\tdescription = \u0026lt;\u0026quot;@ internal @\u0026quot;\u0026gt;\r","\t\t\t\t\u0026gt;\r","\t\t\t\t[\u0026quot;at0004\u0026quot;] = \u0026lt;\r","\t\t\t\t\ttext = \u0026lt;\u0026quot;扩展\u0026quot;\u0026gt;\r","\t\t\t\t\tdescription = \u0026lt;\u0026quot;采集本地内容或者是与其他参考模型/形式化体系保持一致时所需的其他信息。\u0026quot;\u0026gt;\r","\t\t\t\t\tcomment = \u0026lt;\u0026quot;本地信息要求/需求，或者是与 FHIR 保持一致时所需的其他元数据。\u0026quot;\u0026gt;\r","\t\t\t\t\u0026gt;\r","\t\t\t\t[\u0026quot;at0005\u0026quot;] = \u0026lt;\r","\t\t\t\t\ttext = \u0026lt;\u0026quot;设备\u0026quot;\u0026gt;\r","\t\t\t\t\tdescription = \u0026lt;\u0026quot;旨在采集/记录用来报告数据的设备。\u0026quot;\u0026gt;\r","\t\t\t\t\u0026gt;\r","\t\t\t\t[\u0026quot;at0006\u0026quot;] = \u0026lt;\r","\t\t\t\t\ttext = \u0026lt;\u0026quot;信息来源\u0026quot;\u0026gt;\r","\t\t\t\t\tdescription = \u0026lt;\u0026quot;关于报告之中所包含信息的一个或多个来源类型。\u0026quot;\u0026gt;\r","\t\t\t\t\tcomment = \u0026lt;\u0026quot;当信息来源不同于作者/编纂者或创作者时（如“患者”或“[非正规]照护人员”），可以使用本数据元。\u0026quot;\u0026gt;\r","\t\t\t\t\u0026gt;\r","\t\t\t\u0026gt;\r","\t\t\u0026gt;\r","\t\t[\u0026quot;it\u0026quot;] = \u0026lt;\r","\t\t\titems = \u0026lt;\r","\t\t\t\t[\u0026quot;at0000\u0026quot;] = \u0026lt;\r","\t\t\t\t\ttext = \u0026lt;\u0026quot;Dati auto-riportati\u0026quot;\u0026gt;\r","\t\t\t\t\tdescription = \u0026lt;\u0026quot;Contenitore generico per informazioni fornite da un individuo.\u0026quot;\u0026gt;\r","\t\t\t\t\u0026gt;\r","\t\t\t\t[\u0026quot;at0003\u0026quot;] = \u0026lt;\r","\t\t\t\t\ttext = \u0026lt;\u0026quot;Item tree\u0026quot;\u0026gt;\r","\t\t\t\t\tdescription = \u0026lt;\u0026quot;@ internal @\u0026quot;\u0026gt;\r","\t\t\t\t\u0026gt;\r","\t\t\t\t[\u0026quot;at0004\u0026quot;] = \u0026lt;\r","\t\t\t\t\ttext = \u0026lt;\u0026quot;Estensione\u0026quot;\u0026gt;\r","\t\t\t\t\tdescription = \u0026lt;\u0026quot;Informazioni aggiuntive richieste per registrare contenuti locali o per allinearsi ad altri modelli/formalismi di riferimento.\u0026quot;\u0026gt;\r","\t\t\t\t\tcomment = \u0026lt;\u0026quot;*For example: local information requirements or additional metadata to align with FHIR.(en)\u0026quot;\u0026gt;\r","\t\t\t\t\u0026gt;\r","\t\t\t\t[\u0026quot;at0005\u0026quot;] = \u0026lt;\r","\t\t\t\t\ttext = \u0026lt;\u0026quot;Dispositivo\u0026quot;\u0026gt;\r","\t\t\t\t\tdescription = \u0026lt;\u0026quot;Per registrare il dispositivo utilizzato per riportare i dati.\u0026quot;\u0026gt;\r","\t\t\t\t\u0026gt;\r","\t\t\t\t[\u0026quot;at0006\u0026quot;] = \u0026lt;\r","\t\t\t\t\ttext = \u0026lt;\u0026quot;Fonte di informazione\u0026quot;\u0026gt;\r","\t\t\t\t\tdescription = \u0026lt;\u0026quot;Riguarda uno o più tipi di fonte delle informazioni contenute nel referto.\u0026quot;\u0026gt;\r","\t\t\t\t\tcomment = \u0026lt;\u0026quot;*This data element may be used when the Information source is different to the author or composer. For example: \u0026#39;parent\u0026#39;; or \u0026#39;carer\u0026#39;.(en)\u0026quot;\u0026gt;\r","\t\t\t\t\u0026gt;\r","\t\t\t\u0026gt;\r","\t\t\u0026gt;\r","\t\u0026gt;\r"]}},"title":"public/approval processes/#1 2025_voting/approval_round/openEHR-EHR-COMPOSITION.self_reported_data.v1.adl at main · openehr-finland/public","appPayload":{},"meta":{"title":"public/approval processes/#1 2025_voting/approval_round/openEHR-EHR-COMPOSITION.self_reported_data.v1.adl at main · openehr-finland/public"}}</script>
