غط الدم. مثلا, مستوى القلق أو متلازمة البالطو الأبيض أو الألم أو الحمى أو التغييرات في الضغط الجوي,, إلى آخره\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1053\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"*Intra-arterial(en)\"\u003e\r","\t\t\t\t\tdescription = \u003c\"*Invasive measurement via transducer access line within an artery.(en)\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1054\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"*Systolic pressure formula(en)\"\u003e\r","\t\t\t\t\tdescription = \u003c\"*Formula used to calculate the systolic pressure from from mean arterial pressure (if recorded in data).(en)\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1055\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"*Diastolic pressure formula(en)\"\u003e\r","\t\t\t\t\tdescription = \u003c\"*Formula used to calculate the diastolic pressure from mean arterial pressure (if recorded in data).(en)\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1057\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"*Structured measurement location(en)\"\u003e\r","\t\t\t\t\tdescription = \u003c\"*Structured anatomical location of where the measurement was taken.(en)\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1058\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"*Extension(en)\"\u003e\r","\t\t\t\t\tdescription = \u003c\"*Additional information required to capture local context or to align with other reference models/formalisms.(en)\"\u003e\r","\t\t\t\t\tcomment = \u003c\"*For example: Local hospital departmental infomation or additional metadata to align with FHIR or CIMI equivalents.(en)\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1059\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"*New element(en)\"\u003e\r","\t\t\t\t\tdescription = \u003c\"**(en)\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1056\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"*Dorsum of foot(en)\"\u003e\r","\t\t\t\t\tdescription = \u003c\"**(en)\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\u003e\r","\t\t\u003e\r","\t\t[\"es-ar\"] = \u003c\r","\t\t\titems = \u003c\r","\t\t\t\t[\"at0000\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Presión Arterial\"\u003e\r","\t\t\t\t\tdescription = \u003c\"La medición local de la tensión arterial que deriva de la medida de la presión arterial en la circulación sistémica. Comúnmente el uso de 'presión arterial' se refiere a la medida de la presión de la arteria braquial por encima del pliegue del codo.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0001\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"historia\"\u003e\r","\t\t\t\t\tdescription = \u003c\"historia Nodo estructural\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0003\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"*blood pressure(en)\"\u003e\r","\t\t\t\t\tdescription = \u003c\"*@ internal @(en)\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0004\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Sistólica\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Presión arterial sistólica pico - medido en sístole o la fase de contracción del ciclo cardíaco\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0005\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Diástole\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Presión arterial sistémica mínima - medido durante la diástole o fase de relajación del ciclo cardíaco.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0006\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"*Any event(en)\"\u003e\r","\t\t\t\t\tdescription = \u003c\"*Default, unspecified point in time or interval event which may be explicitly defined in a template or at run-time.(en)\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0007\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"*state structure(en)\"\u003e\r","\t\t\t\t\tdescription = \u003c\"*@ internal @(en)\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0008\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Posición\"\u003e\r","\t\t\t\t\tdescription = \u003c\"La posición del individuo en el momento del registro.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0011\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"estructura de lista\"\u003e\r","\t\t\t\t\tdescription = \u003c\"estructura tipo lista\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0013\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Tamaño del manguito\"\u003e\r","\t\t\t\t\tdescription = \u003c\"El tamaño del manguito usado para la toma de la presión arterial\"\u003e\r","\t\t\t\t\tcomment = \u003c\"Perloff D, Grim C, Flack J, Frohlich ED, Hill M, McDonald M, Morgenstern BZ. Presión arterial humana determinado por esfingomanómetro. Circulation 1993;88;2460-2470.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0014\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"*Location of measurement(en)\"\u003e\r","\t\t\t\t\tdescription = \u003c\"*Simple body site where blood pressure was measured.(en)\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0015\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Muslo Adulto\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Un manguito usado para el muslo del adulto - cámara de caucho aproximadamente de 20cm x 42 cm\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0016\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Adulto grande\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Un manguito para adultos con brazos mas grandes - cámara de caucho aproximadamente de 16cm x 38cm.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0017\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Adulto\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Un manguito estándar para adulto - cámara de caucho approximadamente de 13cm x 30cm.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0025\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Brazo derecho\"\u003e\r","\t\t\t\t\tdescription = \u003c\"El brazo derecho del individuo\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0026\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Brazo izquierdo\"\u003e\r","\t\t\t\t\tdescription = \u003c\"El brazo izquierdo del individuo\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0027\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Muslo derecho\"\u003e\r","\t\t\t\t\tdescription = \u003c\"El muslo derecho del individuo\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0028\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Muslo izquierdo\"\u003e\r","\t\t\t\t\tdescription = \u003c\"El muslo izquierdo del individuo\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0033\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"*Comment(en)\"\u003e\r","\t\t\t\t\tdescription = \u003c\"*Additional narrative about the measurement, not captured in other fields.(en)\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1000\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"De pie\"\u003e\r","\t\t\t\t\tdescription = \u003c\"De pie al momento de la medición de la tensión arterial.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1001\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Sentado\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Sentado (en la cama o en una silla) durante el registro de la presión arterial \"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1002\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Reclinado\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Reclinado (semisentado) durante el registro de la presión arterial\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1003\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Acostado\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Acostado horizontal durante la medición de la presión arterial\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1005\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"*Tilt(en)\"\u003e\r","\t\t\t\t\tdescription = \u003c\"*The craniocaudal tilt of the surface on which the person is lying at the time of measurement.(en)\"\u003e\r","\t\t\t\t\tcomment = \u003c\"*PLEASE NOTE: '°' is a valid UCUM unit. Please use 'deg' as the correct unit.(en)\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1006\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Presión Arterial Media\"\u003e\r","\t\t\t\t\tdescription = \u003c\"La presión arterial promedio que ocurre durante el ciclo entero de la contracción y relajación del corazon\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1007\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Presión de Pulso\"\u003e\r","\t\t\t\t\tdescription = \u003c\"La diferencia entre la presión sistólica y la presión diastólica\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1008\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Adulto pequeño\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Un manguito usado para adulto pequeño - cámara de caucho approximadamente de 10cm x 24cm.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1009\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Pediátrico/Niño\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Un manguito que es apropiado para un niño o un adulto con brazos delgados - cámara de caucho approximadamente 8cm x 21cm.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1010\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Punto final diastólica\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Registro usando los sonidos de Korotkoff para determinar la presión diastólica\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1011\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Fase IV\"\u003e\r","\t\t\t\t\tdescription = \u003c\"El cuarto sonido de Korotkoff se identifica como una abrupta amortiguación de sonidos.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1012\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Fase V\"\u003e\r","\t\t\t\t\tdescription = \u003c\"El quinto sonido de Korotkoff se identifica como la ausencia de sonidos a medida que la presión del manguito insuflado cae por debajo de la presión arterial diastólica.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1014\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Acostado e inclinado levemente sobre su costado izquierdo\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Acostado horizontal e inclinado levemente sobre su costado izquierdo. Comúnmente se requiere durante el último trimestre del embarazo para aliviar la compresión aortocava.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1018\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Infantil\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Un manguito usado para infantes - cámara de caucho approximadamente de 5cm x 15cm.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1019\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Neonatal\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Un manguito usado para neonatos, asumiendo que es del tamaño adecuado para la madurez y el peso corporal del neonato.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1020\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Muñeca derecha\"\u003e\r","\t\t\t\t\tdescription = \u003c\"La muñeca derecha del individuo.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1021\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Muñeca izquierda\"\u003e\r","\t\t\t\t\tdescription = \u003c\"La muñeca inquierda del individuo.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1025\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Dispositivo\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Detalles del esfingomanómetro u otro dispositivo usado para medir la presión arterial.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1026\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Tobillo derecho\"\u003e\r","\t\t\t\t\tdescription = \u003c\"El tobillo derecho del individuo.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1030\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Ejercicio\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Detalles de la actividad física realizados durante la medición de la presión arterial \"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1031\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Tobillo izquierdo\"\u003e\r","\t\t\t\t\tdescription = \u003c\"El tobillo izquierdo del individuo\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1032\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"*Finger(en)\"\u003e\r","\t\t\t\t\tdescription = \u003c\"*A finger of the individual.(en)\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1035\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Método\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Método de la medición de la presión arterial\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1036\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Auscultación\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Método de la medición de la presión arterial externa, usando un estetoscopio y los sonidos de Korotkoff\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1037\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Palpación\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Método de medición de la presión arterial externa, usando palpación (normalmente de la arteria humeral o radial).\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1038\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Fórmula de la Presión Arterial Media (PAM)\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Fórmula usada para calcular la PAM (si se registra en el campo data)\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1039\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Máquina\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Método de medición de la presión arterial externa, utilizando un monitor automático (mecánico) de presión arterial\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1040\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Invasivo\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Método de medición de la presión arterial interna o sea invasiva: punción de la piel y la introducción de un cateter para medir dentro de un vaso sanguíneo.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1042\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Promedio de 24 horas\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Estimativo de la media de la presión arterial sobre un período de 24 horas\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1043\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Estado del sueño\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Estado del sueño - soporta la interpretación de los registros de presión arterial ambulatorios de 24 horas\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1044\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Alerta y despierto\"\u003e\r","\t\t\t\t\tdescription = \u003c\"El sujeto esta plenamente consciente\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1045\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Dormido\"\u003e\r","\t\t\t\t\tdescription = \u003c\"El sujeto esta en un estado natural de sueño corporal\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1051\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"*Toe(en)\"\u003e\r","\t\t\t\t\tdescription = \u003c\"*A toe of the individual.(en)\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1052\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Factores confluentes\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Comentario y registro sobre otros factores que pueden incidir sobre la medición de la presión arterial. Por ejemplo: nivel de ansiedad o \\\"síndrome del guardapolvo blanco\\\"; dolor o fiebre; cambios en la presión atmosférica etc.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1053\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"*Intra-arterial(en)\"\u003e\r","\t\t\t\t\tdescription = \u003c\"*Invasive measurement via transducer access line within an artery.(en)\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1054\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"*Systolic pressure formula(en)\"\u003e\r","\t\t\t\t\tdescription = \u003c\"*Formula used to calculate the systolic pressure from from mean arterial pressure (if recorded in data).(en)\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1055\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"*Diastolic pressure formula(en)\"\u003e\r","\t\t\t\t\tdescription = \u003c\"*Formula used to calculate the diastolic pressure from mean arterial pressure (if recorded in data).(en)\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1057\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"*Structured measurement location(en)\"\u003e\r","\t\t\t\t\tdescription = \u003c\"*Structured anatomical location of where the measurement was taken.(en)\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1058\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"*Extension(en)\"\u003e\r","\t\t\t\t\tdescription = \u003c\"*Additional information required to capture local context or to align with other reference models/formalisms.(en)\"\u003e\r","\t\t\t\t\tcomment = \u003c\"*For example: Local hospital departmental infomation or additional metadata to align with FHIR or CIMI equivalents.(en)\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1059\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"*New element(en)\"\u003e\r","\t\t\t\t\tdescription = \u003c\"**(en)\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1056\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"*Dorsum of foot(en)\"\u003e\r","\t\t\t\t\tdescription = \u003c\"**(en)\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\u003e\r","\t\t\u003e\r","\t\t[\"pt-br\"] = \u003c\r","\t\t\titems = \u003c\r","\t\t\t\t[\"at0000\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Pressão Arterial\"\u003e\r","\t\t\t\t\tdescription = \u003c\"A medida local da pressão sanguínea arterial, a qual é uma substituta da pressão arterial na circulação arterial sistêmica. Mais comumente o uso do termo pressão arterial se refere à medida da pressão da artéria braquial no antebraço.\"\u003e\r","\t\t\t\t\tcomment = \u003c\"*Most commonly, use of the term 'blood pressure' refers to measurement of brachial artery pressure in the upper arm.(en)\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0001\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"história\"\u003e\r","\t\t\t\t\tdescription = \u003c\"nodo Estrutural história\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0003\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"*blood pressure(en)\"\u003e\r","\t\t\t\t\tdescription = \u003c\"*@ internal @(en)\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0004\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Sistólica\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Pressão arterial sistêmica máxima - medida na fase sistólica ou de contração do ciclo cardíaco.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0005\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Diastólica\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Pressão arterial sistêmica mínima - medida na fase diastólica ou de dilatação do ciclo cardíaco.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0006\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Qualquer evento\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Padrão, ponto especificado no tempo ou evento de intervalo que pode ser explicitamente definido em um modelo ou em tempo de execução.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0007\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"*state structure(en)\"\u003e\r","\t\t\t\t\tdescription = \u003c\"*@ internal @(en)\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0008\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Posição\"\u003e\r","\t\t\t\t\tdescription = \u003c\"A posição do sujeito na hora da medida.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0011\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"estrutura de lista\"\u003e\r","\t\t\t\t\tdescription = \u003c\"estrutura de lista\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0013\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Tamanho da braçadeira\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Tamanho da braçadeira usada para medir a pressão arterial.\"\u003e\r","\t\t\t\t\tcomment = \u003c\"Sem comentários\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0014\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Localização da medição\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Local do corpo simples em que a pressão arterial foi medida.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0015\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Coxa de adulto\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Uma braçadeira usada na coxa de um aduto - manguito de aproximadamente 20cm x 42cm.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0016\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Adulto Grande\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Uma braçadeira para adultos com braço largo - manguito de aproximadamente 16cm x 38cm.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0017\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Adulto\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Uma braçadeira padrão para adultos - manguito de aproximadamente 13cm x 30cm.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0025\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Braço direito\"\u003e\r","\t\t\t\t\tdescription = \u003c\"O braço direito da pessoa.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0026\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Braço esquerdo\"\u003e\r","\t\t\t\t\tdescription = \u003c\"O braço esquerdo da pessoa.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0027\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Coxa direita\"\u003e\r","\t\t\t\t\tdescription = \u003c\"A coxa direita da pessoa.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0028\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Coxa esquerda\"\u003e\r","\t\t\t\t\tdescription = \u003c\"A coxa esquerda da pessoa.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0033\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Comentário\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Narrativa adicional sobre a medição, não capturada em outros campos.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1000\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Em pé\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Em pé na hora da medida da pressão arterial.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1001\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Sentado\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Sentado (por exemplo na cama ou em uma cadeira) na hora da medida da pressão arterial.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1002\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Reclinado\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Reclinado na hora da medida da pressão arterial.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1003\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Deitado\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Deitado sem reclinação hora da medida da pressão arterial.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1005\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Inclinado\"\u003e\r","\t\t\t\t\tdescription = \u003c\"A inclinação craniocaudal da superfície na qual a pessoa está deitada no momento da medição.\"\u003e\r","\t\t\t\t\tcomment = \u003c\"* ATENÇÃO: '°' é uma unidade UCUM válida. Por favor, use 'graus' como a unidade correta.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1006\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Pressão arterial Média\"\u003e\r","\t\t\t\t\tdescription = \u003c\"A pressão arterial média que ocorrre ao longo de todo o ciclo de contração e dilatação do coração.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1007\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Pressão de Pulso\"\u003e\r","\t\t\t\t\tdescription = \u003c\"A diferença entre a pressão sistólica e diastólica.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1008\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Adulto pequeno\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Uma braçadeira usada para adultos pequenos -manguito de aproximadamente 10cm x 24cm.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1009\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Criança/Pediátrico\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Manguito apropriao para uma criança ou um adulto com um braço fino - bolsa de aproximadamente 8cm x 21cm.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1010\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Final da diástole\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Registro do som Korotkoff usado para determinar a pressão arterial diastólica, usando o método auscultativo.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1011\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Fhase IV.\"\u003e\r","\t\t\t\t\tdescription = \u003c\"O quarto som de Korotkoff é identificado como um súbito abafamento dos sons.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1012\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Phase V\"\u003e\r","\t\t\t\t\tdescription = \u003c\"O quinto som de Korotkoff é identificado pela ausência de sons, pois a pressão da braçadeira cai abaixo da pressão diastólica do sangue.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1014\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Deitado com inclinação para esquerda\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Deitado sem reclinação com alguma inclinação lateral, usualmente com angulação para o lado esquerdo. Comumente requerido no último trimestre da gravidez para aliviar a compressão aortocaval.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1018\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Criança pequena\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Uma braçadeira utilizada em crianças pequenas - manguito de aproximadamente 5cm x 15cm.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1019\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Neonatal\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Uma braçadeira usada para um recém-nascido, supondo que o tamanho é apropriado para a maturidade e o peso ao nascer do neonato.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1020\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Pulso direito\"\u003e\r","\t\t\t\t\tdescription = \u003c\"O pulso direito da pessoa.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1021\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Pulso esquerdo\"\u003e\r","\t\t\t\t\tdescription = \u003c\"O pulso esquerdo da pessoa.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1025\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Aparelho\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Detalhes sobre o esfigmomanômetro ou outro aparelho utilizado para medir a pressão sanguínea.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1026\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Tornozelo direito\"\u003e\r","\t\t\t\t\tdescription = \u003c\"O tornozelo direito da pessoa.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1030\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Esforço físico\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Detalhes sobre atividade física realizada na hora da medida da pressão arterial.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1031\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Tornozelo esquerdo\"\u003e\r","\t\t\t\t\tdescription = \u003c\"O tornozelo esquerdo da pessoa.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1032\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Dedo\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Um dedo do indivíduo.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1035\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Método\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Método de medida da pressão arterial.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1036\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Ausculta\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Método de medir a pressão externamente, usando o estetoscópiso e os sons Korotkoff.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1037\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Palpação\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Método de medir a pressão arterial externamente, usando a palpação (geralmente artérias braquiais ou radiais).\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1038\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Fórmula de Pressão Arterial Média\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Fórmula usada para calcular a pressão arterial média (PAM), se registrada em dados.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1039\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Aparelho de pressão\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Método de medir a pressão arterial externamente, usando o aparelho de pressão arterial.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1040\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Invasivo\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Método de medir a pressão arterial internamente, isto é, envolvendo a penetração da pele e a medida interior dos vasos sanguíneos.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1042\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Media de 24 horas\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Estimativa da pressão arterial média em um período de 24 horas.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1043\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Status do sono\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Status do sono - apóia a interpretação do registro do mapa de pressão arterial (ambulatorial de 24 horas).\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1044\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Alerta e acordado\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Sujeito está totalmente consciente.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1045\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Dormindo\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Sujeito está no estado natural de descanso corporal.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1051\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Dedo do pé\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Um dedo do pé do indivíduo.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1052\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Fatores confundidores\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Comentários sobre e registros de outros fatores incidentais que possam estar contribuindo na medida da pressão sanguínea. Por exemplo, nível de ansiedade ou \\\"síndrome do jaleco branco\\\"; dor ou febre; mudanças na pressão atmosférica, etc.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1053\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Intra-arterial\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Medição invasiva via linha de acesso do transdutor dentro de uma artéria.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1054\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Fórmula de pressão sistólica\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Fórmula utilizada para calcular a pressão sistólica a partir da pressão arterial média (se registrada nos dados).\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1055\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Fórmula da pressão diastólica\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Fórmula utilizada para calcular a pressão diastólica da pressão arterial média (se registrada nos dados).\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1056\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Dorso do pé\"\u003e\r","\t\t\t\t\tdescription = \u003c\"O dorso do pé do indivíduo.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1057\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Localização de medição estruturada\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Localização anatômica estruturada de onde a medição foi feita.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1058\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Extensão\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Informações adicionais necessárias para capturar o contexto local ou para alinhar com outros modelos / formalismos de referência.\"\u003e\r","\t\t\t\t\tcomment = \u003c\"Por exemplo: Informações locais de departamentos de hospitais ou metadados adicionais para alinhar a equivalentes FHIR ou CIMI\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1059\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Interpretação clínica\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Palavra única, frase ou breve descrição que representa o significado clínico e o significado da medida da pressão arterial.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\u003e\r","\t\t\u003e\r","\t\t[\"ko\"] = \u003c\r","\t\t\titems = \u003c\r","\t\t\t\t[\"at0000\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"혈압\"\u003e\r","\t\t\t\t\tdescription = \u003c\"체순환에서 동맥압을 대신하는 동맥혈압의 국소 측정. 보통은 '혈압'이라는 용어의 사용은 상완에서 상완동맥의 측정을 의미함.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0001\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"*history(en)\"\u003e\r","\t\t\t\t\tdescription = \u003c\"*History Structural node.(en)\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0003\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"*blood pressure(en)\"\u003e\r","\t\t\t\t\tdescription = \u003c\"*@ internal @(en)\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0004\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"수축기\"\u003e\r","\t\t\t\t\tdescription = \u003c\"최대 체동맥 혈압 - 심장 싸이클의 수축기에서 측정.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0005\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"이완기\"\u003e\r","\t\t\t\t\tdescription = \u003c\"최소 체동맥 혈압 - 심장 싸이클의 이완기에서 측정됨.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0006\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"*Any event(en)\"\u003e\r","\t\t\t\t\tdescription = \u003c\"*Default, unspecified point in time or interval event which may be explicitly defined in a template or at run-time.(en)\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0007\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"*state structure(en)\"\u003e\r","\t\t\t\t\tdescription = \u003c\"*@ internal @(en)\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0008\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"자세\"\u003e\r","\t\t\t\t\tdescription = \u003c\"측정 시에 대상의 자세\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0011\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"*Tree(en)\"\u003e\r","\t\t\t\t\tdescription = \u003c\"*List structure.(en)\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0013\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Cuff 크기\"\u003e\r","\t\t\t\t\tdescription = \u003c\"혈압 측정을 위해 사용되는 cuff의 크기.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0014\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"*Location of measurement(en)\"\u003e\r","\t\t\t\t\tdescription = \u003c\"*Simple body site where blood pressure was measured.(en)\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0015\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"성인 허벅지\"\u003e\r","\t\t\t\t\tdescription = \u003c\"성인 허벅지을 위한 cuff - bladder가 약 20cm x 42cm.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0016\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"*큰 성인(ko)\"\u003e\r","\t\t\t\t\tdescription = \u003c\"*큰 팔을 가진 성인을 위한 cuff - bladder가 약 16cm x 38cm.(ko)\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0017\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"*성인(ko)\"\u003e\r","\t\t\t\t\tdescription = \u003c\"*성인을 위한 표준인 cuff - bladder가 약 13cm x 30cm.(ko)\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0025\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"*우측 팔(ko)\"\u003e\r","\t\t\t\t\tdescription = \u003c\"*사람의 우측 팔.(ko)\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0026\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"*좌측 팔(ko)\"\u003e\r","\t\t\t\t\tdescription = \u003c\"*사람의 좌측 팔.(ko)\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0027\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"*우측 허벅지(ko)\"\u003e\r","\t\t\t\t\tdescription = \u003c\"*사람의 우측 허벅지.(ko)\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0028\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"*좌측 허벅지(ko)\"\u003e\r","\t\t\t\t\tdescription = \u003c\"*사람의 좌측 허벅지.(ko)\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0033\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"*Comment(en)\"\u003e\r","\t\t\t\t\tdescription = \u003c\"*Additional narrative about the measurement, not captured in other fields.(en)\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1000\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"선 자세\"\u003e\r","\t\t\t\t\tdescription = \u003c\"혈압측정 시에 서있는 자세.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1001\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"앉은 자세\"\u003e\r","\t\t\t\t\tdescription = \u003c\"혈압 측정시에 앉은 자세(침대 또는 의자).\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1002\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"비스듬한 자세\"\u003e\r","\t\t\t\t\tdescription = \u003c\"혈압 측정시에 비스듬한 자세(reclining).\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1003\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"누운 자세\"\u003e\r","\t\t\t\t\tdescription = \u003c\"혈압 측정시에 바로 누운 자세.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1005\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"*Tilt(en)\"\u003e\r","\t\t\t\t\tdescription = \u003c\"*The craniocaudal tilt of the surface on which the person is lying at the time of measurement.(en)\"\u003e\r","\t\t\t\t\tcomment = \u003c\"*PLEASE NOTE: '°' is a valid UCUM unit. Please use 'deg' as the correct unit.(en)\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1006\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"평균 동맥압\"\u003e\r","\t\t\t\t\tdescription = \u003c\"심장의 수축과 이완 싸이클 전체과정 동안에 발생하는 평균 동맥압.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1007\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"맥압\"\u003e\r","\t\t\t\t\tdescription = \u003c\"수축기와 이완기 혈압 간의 차이.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1008\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"*작은 성인(ko)\"\u003e\r","\t\t\t\t\tdescription = \u003c\"*작은 성인을 위해 사용되는 cuff - bladder가 약 10cm x 24cm.(ko)\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1009\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"*소아/아동(ko)\"\u003e\r","\t\t\t\t\tdescription = \u003c\"*아동이나 얋은 팔을 가진 성인에게 적합한 cuff - bladder가 약 8cm x 21cm.(ko)\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1010\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"*이완기 종점(ko)\"\u003e\r","\t\t\t\t\tdescription = \u003c\"*청진법을 이용하여 이완기 압력을 결정하는데 사용되는 Korotkoff sound를 기록.(ko)\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1011\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"*Phase IV(en)\"\u003e\r","\t\t\t\t\tdescription = \u003c\"*4번째 Korotkoff sound가 갑작스런 약해지는 소리로 확인된다.(ko)\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1012\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"*Phase V(en)\"\u003e\r","\t\t\t\t\tdescription = \u003c\"*5번째 Korotkoff sound는 cuff 압력이 이완기 혈압 아래로 떨어져 소리가 없어짐으로써 확인된다.(ko)\r","\r","\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1014\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"왼쪽으로 누운 자세\"\u003e\r","\t\t\t\t\tdescription = \u003c\"보통 왼쪽으로 기울린, 옆쪽으로 기울여 누운 자세. 보통 임신 3기에 동정맥압력을 완화하기위해 필요함.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1018\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"*영아(ko)\"\u003e\r","\t\t\t\t\tdescription = \u003c\"*영아을 위해 사용되는 cuff - bladder가 약 5cm x 15cm.(ko)\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1019\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"*신생아(ko)\"\u003e\r","\t\t\t\t\tdescription = \u003c\"*신생아를 위해 사용되는 cuff, cuff는 신생아의 성숙도와 몸무게에 대한 적절한 크기가 가정됨.(ko)\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1020\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"*우측 손목(ko)\"\u003e\r","\t\t\t\t\tdescription = \u003c\"*대상의 우측 손목.(ko)\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1021\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"*좌측 손목(ko)\"\u003e\r","\t\t\t\t\tdescription = \u003c\"*대상의 좌측 손목.(ko)\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1025\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"*장비(ko)\"\u003e\r","\t\t\t\t\tdescription = \u003c\"*혈압을 측정하는데 사용되는 혈압계 또는 기타 장비에 대한 상세내용.(ko)\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1026\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"*우측 발목(ko)\"\u003e\r","\t\t\t\t\tdescription = \u003c\"*대상의 우측 발목.(ko)\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1030\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"노력\"\u003e\r","\t\t\t\t\tdescription = \u003c\"혈압 측정시에 수행 중인 육체활동에 대한 상세내용.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1031\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"*좌측 발목(ko)\"\u003e\r","\t\t\t\t\tdescription = \u003c\"**대상의 좌측 발목.(ko)\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1032\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"*Finger(en)\"\u003e\r","\t\t\t\t\tdescription = \u003c\"*A finger of the individual.(en)\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1035\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"*측정 방법(ko)\"\u003e\r","\t\t\t\t\tdescription = \u003c\"*혈압 측정의 방법.(ko)\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1036\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"*청진(ko)\"\u003e\r","\t\t\t\t\tdescription = \u003c\"*청진기와 Korotkoff sounds을 사용하여 외부에서 혈압을 측정하는 방법.(ko)\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1037\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"*타진(ko)\"\u003e\r","\t\t\t\t\tdescription = \u003c\"*(보통 상완 또는 요골동맥의) 타진을 사용하여 외부에서 혈압을 측정하는 방법.(ko)\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1038\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"*평균 동맥압 공식(ko)\"\u003e\r","\t\t\t\t\tdescription = \u003c\"*(데이터 내에 기록되어 있다면) MAP를 계산하는데 사용되는 공식.(ko)\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1039\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"*장비(ko)\"\u003e\r","\t\t\t\t\tdescription = \u003c\"*혈압 측정 장비를 사용하여 외부에서 혈압을 측정하는 방법.(ko)\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1040\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"*침습적 방법(ko)\"\u003e\r","\t\t\t\t\tdescription = \u003c\"*내부에서 즉 피부를 통과하여 혈관 내에서 혈압을 측정하는 방법.(ko)\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1042\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"24시간 평균\"\u003e\r","\t\t\t\t\tdescription = \u003c\"24시간 동안의 평균 혈압의 추정.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1043\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"수면 상태\"\u003e\r","\t\t\t\t\tdescription = \u003c\"수면 상태 - 24시간 활동 혈압기록에 대한 해석 지원.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1044\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"각성과 기상 상태\"\u003e\r","\t\t\t\t\tdescription = \u003c\"대상은 완전한 의식이 있다.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1045\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"수면 상태\"\u003e\r","\t\t\t\t\tdescription = \u003c\"대상은 신체적으로 자연적인 휴식 상태에 있다.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1051\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"*Toe(en)\"\u003e\r","\t\t\t\t\tdescription = \u003c\"*A toe of the individual.(en)\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1052\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"혼란변수\"\u003e\r","\t\t\t\t\tdescription = \u003c\"혈압측정에 영향을 줄 수 있는 기타 우연한 변수들에 대한 코멘트와 기록. 예를 들어, 불안 또는 '백의신드롬'의 레벨; 통증 또는 발열; 대기압의 변화 등.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1053\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"*Intra-arterial(en)\"\u003e\r","\t\t\t\t\tdescription = \u003c\"*Invasive measurement via transducer access line within an artery.(en)\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1054\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"*Systolic pressure formula(en)\"\u003e\r","\t\t\t\t\tdescription = \u003c\"*Formula used to calculate the systolic pressure from from mean arterial pressure (if recorded in data).(en)\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1055\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"*Diastolic pressure formula(en)\"\u003e\r","\t\t\t\t\tdescription = \u003c\"*Formula used to calculate the diastolic pressure from mean arterial pressure (if recorded in data).(en)\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1057\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"*Structured measurement location(en)\"\u003e\r","\t\t\t\t\tdescription = \u003c\"*Structured anatomical location of where the measurement was taken.(en)\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1058\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"*Extension(en)\"\u003e\r","\t\t\t\t\tdescription = \u003c\"*Additional information required to capture local context or to align with other reference models/formalisms.(en)\"\u003e\r","\t\t\t\t\tcomment = \u003c\"*For example: Local hospital departmental infomation or additional metadata to align with FHIR or CIMI equivalents.(en)\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1059\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"*New element(en)\"\u003e\r","\t\t\t\t\tdescription = \u003c\"**(en)\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1056\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"*Dorsum of foot(en)\"\u003e\r","\t\t\t\t\tdescription = \u003c\"**(en)\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\u003e\r","\t\t\u003e\r","\t\t[\"es\"] = \u003c\r","\t\t\titems = \u003c\r","\t\t\t\t[\"at0000\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Presión arterial\"\u003e\r","\t\t\t\t\tdescription = \u003c\"La medición local de la presión arterial, que es un sustituto de la presión arterial en la circulación sistémica.\"\u003e\r","\t\t\t\t\tcomment = \u003c\"Por lo general, el término «presión arterial» se refiere a la medición de la presión en la arteria braquial, situada en la parte superior del brazo.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0001\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Historia\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Nodo estructural de historia.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0003\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"blood pressure\"\u003e\r","\t\t\t\t\tdescription = \u003c\"@ internal @\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0004\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Sistólica\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Presión arterial sistémica máxima - medida en la fase sistólica o de contracción del ciclo cardíaco.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0005\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Diastólica\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Presión arterial sistémica mínima - medida en la fase diastólica o de relajación del ciclo cardíaco.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0006\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Cualquier evento\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Evento predeterminado, sin especificar en el tiempo o intervalo, que puede definirse explícitamente en una plantilla o en tiempo de ejecución.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0007\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"state structure\"\u003e\r","\t\t\t\t\tdescription = \u003c\"@ internal @\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0008\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Posición\"\u003e\r","\t\t\t\t\tdescription = \u003c\"La posición del individuo en el momento de la medición.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0011\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Árbol\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Estructura de la lista.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0013\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Tamaño del manguito\"\u003e\r","\t\t\t\t\tdescription = \u003c\"El tamaño del manguito utilizado para medir la presión arterial.\"\u003e\r","\t\t\t\t\tcomment = \u003c\"Perloff D, Grim C, Flack J, Frohlich ED, Hill M, McDonald M, Morgenstern BZ. Human blood pressure determination by sphygmomanometry. Circulation 1993;88;2460-2470.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0014\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Localización de la medición\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Zona del cuerpo donde se midió la presión arterial.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0015\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Muslo Adulto\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Un manguito utilizado para el muslo de un adulto.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0016\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Adulto Grande\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Un manguito para adultos con brazos más grandes.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0017\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Adulto\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Un manguito estándar para adultos.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0025\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Brazo derecho\"\u003e\r","\t\t\t\t\tdescription = \u003c\"El brazo derecho de la persona.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0026\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Brazo izquierdo\"\u003e\r","\t\t\t\t\tdescription = \u003c\"El brazo izquierdo de la persona.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0027\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Muslo derecho\"\u003e\r","\t\t\t\t\tdescription = \u003c\"El muslo derecho de la persona.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0028\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Muslo izquierdo\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Muslo izquierdo del paciente\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0033\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Comentario\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Información adicional sobre la medición que no se recoge en otros campos.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1000\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"De pie\"\u003e\r","\t\t\t\t\tdescription = \u003c\"De pie en el momento de la medición de la presión arterial.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1001\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Sentado\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Sentado (por ejemplo, en la cama o en una silla) en el momento de la medición de la presión arterial.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1002\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Reclinado\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Reclinado en el momento de la medición de la presión arterial.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1003\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Acostado\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Acostado en el momento de la medición de la presión arterial.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1005\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Inclinación\"\u003e\r","\t\t\t\t\tdescription = \u003c\"La inclinación craneocaudal de la superficie sobre la que se encuentra la persona en el momento de la medición.\"\u003e\r","\t\t\t\t\tcomment = \u003c\"NOTA: \\\"°\\\" es una unidad válida en UCUM. Utilice \\\"deg\\\" como unidad correcta.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1006\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Presión arterial media\"\u003e\r","\t\t\t\t\tdescription = \u003c\"La presión arterial media que se produce a lo largo de todo el ciclo de contracción y relajación del corazón.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1007\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Presión del pulso\"\u003e\r","\t\t\t\t\tdescription = \u003c\"La diferencia entre la presión sistólica y la presión diastólica.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1008\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Adulto Pequeño\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Un manguito utilizado para adultos de complexión pequeña.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1009\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Pediátrico/Niños\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Un manguito adecuado para niños o adultos con brazos delgados.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1010\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Punto final diastólico\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Registre qué sonido de Korotkoff se utiliza para determinar la presión diastólica mediante el método auscultativo.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1011\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Fase IV\"\u003e\r","\t\t\t\t\tdescription = \u003c\"El cuarto sonido de Korotkoff se identifica como un abrupto amortiguamiento de los sonidos.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1012\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Fase V\"\u003e\r","\t\t\t\t\tdescription = \u003c\"El quinto sonido de Korotkoff se identifica por la ausencia de sonidos cuando la presión del manguito desciende por debajo de la presión arterial diastólica.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1014\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Tumbado con inclinación hacia la izquierda\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Acostada boca arriba con cierta inclinación lateral, normalmente hacia el lado izquierdo. Se suele requerir en el último trimestre del embarazo para aliviar la compresión aortocava.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1018\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Bebé\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Un manguito utilizado para bebés.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1019\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Neonatal\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Un manguito utilizado para un recién nacido, suponiendo que el manguito sea del tamaño adecuado para la madurez y el peso al nacer del recién nacido.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1020\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Muñeca derecha\"\u003e\r","\t\t\t\t\tdescription = \u003c\"La muñeca derecha de la persona.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1021\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Muñeca izquierda\"\u003e\r","\t\t\t\t\tdescription = \u003c\"La muñeca izquierda de la persona.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1025\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Dispositivo\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Detalles sobre el esfigmomanómetro u otro dispositivo utilizado para medir la presión arterial.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1026\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Tobillo derecho\"\u003e\r","\t\t\t\t\tdescription = \u003c\"El tobillo derecho de la persona.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1030\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Esfuerzo\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Detalles sobre la actividad física realizada en el momento de la medición de la presión arterial.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1031\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Tobillo izquierdo\"\u003e\r","\t\t\t\t\tdescription = \u003c\"El tobillo izquierdo de la persona.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1032\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Dedo de la mano\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Un dedo de la mano de la persona.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1035\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Método\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Método de medición de la presión arterial.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1036\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Auscultación\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Método para medir la presión arterial de forma externa, utilizando un estetoscopio y los sonidos de Korotkoff.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1037\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Palpación\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Método para medir la presión arterial de forma externa, mediante palpación (normalmente de las arterias braquial o radial).\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1038\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Fórmula de la presión arterial media\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Fórmula utilizada para calcular la presión arterial media (si se registra en los datos).\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1039\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Aparato\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Método para medir la presión arterial de forma externa, utilizando un tensiómetro.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1040\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Invasivo\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Método para medir la presión arterial internamente, es decir, mediante la penetración de la piel y la medición dentro de los vasos sanguíneos.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1042\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Promedio de 24 horas\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Estimación de la presión arterial media durante un periodo de 24 horas.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1043\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Estado del sueño\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Estado del sueño - permite interpretar los registros de presión arterial ambulatoria de 24 horas.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1044\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Despierto\"\u003e\r","\t\t\t\t\tdescription = \u003c\"El individuo está plenamente consciente.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1045\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Durmiendo\"\u003e\r","\t\t\t\t\tdescription = \u003c\"El individuo se encuentra en un estado natural de reposo corporal.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1051\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Dedo del pie\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Un dedo del pie de la persona.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1052\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Factores de confusión\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Comente y registre otros factores incidentales que puedan estar contribuyendo a la medición de la presión arterial. Por ejemplo, el nivel de ansiedad o el «síndrome de la bata blanca», dolor o fiebre, cambios en la presión atmosférica, etc.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1053\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Intraarterial\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Medición invasiva mediante una línea de acceso al transductor dentro de una arteria.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1054\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Fórmula de la presión sistólica\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Fórmula utilizada para calcular la presión sistólica a partir de la presión arterial media (si se registra en los datos).\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1055\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Fórmula de la presión diastólica\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Fórmula utilizada para calcular la presión diastólica a partir de la presión arterial media (si se registra en los datos).\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1056\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Dorso del pie\"\u003e\r","\t\t\t\t\tdescription = \u003c\"El dorso del pie de la persona.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1057\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Lugar de medición estructurado\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Localización anatómica estructurada del lugar donde se tomó la medida.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1058\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Extensión\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Información adicional necesaria para captar el contexto local o para alinearse con otros modelos de referencia/formalismos.\"\u003e\r","\t\t\t\t\tcomment = \u003c\"Por ejemplo: información departamental de hospitales locales o metadatos adicionales para alinearse con los equivalentes FHIR o CIMI.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1059\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Interpretación clínica\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Palabra, frase o breve descripción que representa el significado clínico y la importancia de la medición de la presión arterial.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\u003e\r","\t\t\u003e\r","\t\t[\"nb\"] = \u003c\r","\t\t\titems = \u003c\r","\t\t\t\t[\"at0000\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Blodtrykk\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Måling av blodtrykket som uttrykk for det arterielle blodtrykk i det systemiske kretsløp.\"\u003e\r","\t\t\t\t\tcomment = \u003c\"Vanligvis brukes begrepet \\\"blodtrykk\\\" om måling av brakialt arterietrykk i overarmen.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0001\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Historikk\"\u003e\r","\t\t\t\t\tdescription = \u003c\"History Structural node.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0003\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"*blood pressure(en)\"\u003e\r","\t\t\t\t\tdescription = \u003c\"*@ internal @(en)\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0004\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Systolisk\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Maksimalt systemisk arterielt blodtrykk - målt i systolen, det vil si i hjertets kontraksjonsfase.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0005\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Diastolisk\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Laveste systemiske arterielle blodtrykk - målt i diastolen, det vil si under hjertets relaksasjonsfase.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0006\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Uspesifisert hendelse\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Standard, uspesifisert tidspunkt eller tidsintervall som kan defineres mer eksplisitt i et templat eller i en applikasjon.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0007\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"*state structure(en)\"\u003e\r","\t\t\t\t\tdescription = \u003c\"*@ internal @(en)\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0008\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Stilling\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Individets posisjon ved tidspunktet for målingen.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0011\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Tre\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Struktur liste\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0013\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Mansjettstørrelse\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Størrelse på blodtrykkmansjetten som anvendes til måling av blodtrykket. (Cuffstørrelse)\"\u003e\r","\t\t\t\t\tcomment = \u003c\"Perloff D, Grim C, Flack J, Frohlich ED, Hill M, McDonald M, Morgenstern BZ. Human blood pressure determination by sphygmomanometry. Circulation 1993;88;2460-2470.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0014\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Målested\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Anatomisk sted hvor blodtrykket måles. Bruk listen over interne koder for valg av vanlige målesteder. Bruk fri eller kodet tekst for registrering av mer spesifikke detaljer eller et målested som ikke inngår i listen over vanlige steder. Henvis eventuelt til ekstern terminologi.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0015\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Lår voksne\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Mansjett for bruk rundt låret til voksne individer.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0016\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Store voksne\"\u003e\r","\t\t\t\t\tdescription = \u003c\"En blodtrykksmansjett for voksne med store armer.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0017\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Voksne\"\u003e\r","\t\t\t\t\tdescription = \u003c\"En standard blodtrykksmansjett til voksne.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0025\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Overarm, høyre\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Individets høyre overarm.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0026\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Overarm, venstre\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Individets venstre overarm.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0027\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Lår, høyre\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Individets høyre lår.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0028\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Lår, venstre\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Individets venstre lår.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0033\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Kommentar\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Ytterligere fritekst om målingen, som ikke omfattes av andre felt.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1000\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Stående\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Stående ved tidspunktet for målingen.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1001\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Sittende\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Sittende (for eksempel på en stol eller på en seng med føttene på gulvet) på tidspunkt for blodtrykksmålingen.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1002\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Tilbakelent\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Sittende tilbakelent ca 45º og med beina hevet til samme høyde som hoften på tidspunkt for blodtrykksmålingen.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1003\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Liggende\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Liggende flatt på tidspunkt for blodtrykksmålingen.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1005\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Tilt\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Kranio-caudal tilt av overflaten som individet ligger på på tidspunkt for blodtrykksmåling.\"\u003e\r","\t\t\t\t\tcomment = \u003c\"Negative verdier betegner posisjoner med hodet ned.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1006\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Middelarterietrykk\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Det gjennomsnittlige trykket mot arterieveggen gjennom en enkelt hjertesyklus. Middeltrykk/MAP måles direkte eller beregnes ut fra systolisk og diastolisk trykk ved hjelp av en matematisk formel.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1007\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Pulstrykk\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Differansen mellom det systoliske og diastoliske arterielle blodtrykket.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1008\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Små voksne\"\u003e\r","\t\t\t\t\tdescription = \u003c\"En blodtrykksmansjett for små voksne.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1009\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Barn\"\u003e\r","\t\t\t\t\tdescription = \u003c\"En blodtrykksmansjett til barn eller små voksne med tynne armer.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1010\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Diastolisk endepunkt\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Registrering av hvilken av Korotkofflydene som brukes for å bestemme det diastoliske blodtrykket ved hjelp av auskultasjon.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1011\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Fase IV\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Den fjerde Korotkoff lyd som identifieres som en brå demping av lydene.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1012\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Fase V\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Den femte Korotkoff lyd som identifiseres som fraværet av lyder idet mansjettrykket faller under det diastoliske blodtrykket.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1014\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Liggende lent mot venstre\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Liggende flatt med noe lateral tilt, vanligvis vinklet mot venstre side. Vanligvis nødvendig i siste trimester av svangerskapet for å avlaste aortocaval komprimering.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1018\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Spedbarn\"\u003e\r","\t\t\t\t\tdescription = \u003c\"En blodtrykksmansjett til bruk for spedbarn.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1019\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Neonatale\"\u003e\r","\t\t\t\t\tdescription = \u003c\"En blodtrykksmansjett til bruk for neonatale, forutsatt at blodtrykksmansjetten er tilpasset i størrelse for modenhet og fødselsvekt.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1020\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Håndledd, høyre\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Individets høyre håndledd.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1021\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Håndledd, venstre\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Individets venstre håndledd.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1025\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Måleapparat\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Detaljer om sfygmomanometeret eller annet måleapparat brukt til blodtrykksmåling.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1026\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Ankel, høyre\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Individets høyre ankel.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1030\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Fysisk anstrengelse\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Detaljer om fysisk aktivitet på tidspunkt for blodtrykksmåling.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1031\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Ankel, venstre\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Individets venstre ankel.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1032\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Finger\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Individets finger. Dersom identifikasjon av den spesifikke fingeren er nødvendig, kan dette legges inn ved hjelp av feltet med fri eller kodet tekst.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1035\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Målemetode\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Metode for måling av blodtrykket.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1036\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Auskultasjon\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Metode for måling av blodtrykk eksternt, ved hjelp av stetoskop og Korotkofflyder.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1037\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Palpasjon\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Metode for måling av blodtrykket eksternt, ved hjelp av palpasjon (vanligvis av arteriene brachialis eller radialis).\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1038\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Formel for beregning av MAP\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Eventuell formel som er anvendt til beregning av middeltrykket (MAP).\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1039\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Automatisk, non-invasivt\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Metode for non-invasiv måling av blodtrykket ved hjelp av en maskin som automatisk måler blodtrykket, for eksempel et måleapparat eller en blodtrykksmåler for hjemmebruk.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1040\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Automatisk, invasivt\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Metode for måling av blodtrykket invasivt med innleggelse av intravasalkateter i en blodåre.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1042\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"24-timers gjennomsnitt\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Estimert gjennomsnittsblodtrykk over en 24-timers periode.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1043\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Søvnstatus\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Søvnstatus - understøtter tolkning av 24 timers ambulant blodtrykksmåling.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1044\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Våken\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Individet er ved full bevissthet.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1045\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Sovende\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Individet er i den naturlige tilstand av kroppslig hvile.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1051\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Tå\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Individets tå. Dersom identifikasjon av den spesifikke tåen er nødvendig, kan dette legges inn ved hjelp av feltet med fri eller kodet tekst.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1052\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Konfunderende faktorer\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Kommentar til og registrering av andre faktorer som kan påvirke blodtrykksmålingen. For eksempel angst eller \\\"hvit frakk syndrom\\\", smerter eller feber, endringer i atmosfærisk trykk osv.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1053\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Intra-arterielt\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Invasiv måling i en artiere via en transducer.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1054\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Formel for beregning av systolisk trykk\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Formelen som anvendes til beregning av systolisk blodtrykk dersom det benyttes en maskin som måler middeltrykket og beregner systolisk og diastolisk trykk.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1055\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Formel for beregning av diastolisk trykk\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Formelen som anvendes til beregning av diastolisk blodtrykk dersom det benyttes en maskin som måler middeltrykket og beregner systolisk og diastolisk trykk.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1056\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Fotrygg\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Individets fotrygg.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1057\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Strukturert målested\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Strukturert anatomisk lokalisering av stedet målingen ble gjort.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1058\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Tilleggsinformasjon\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Ytterligere informasjon som trengs for å kunne registrere lokalt definert innhold eller for å tilpasse til andre referansemodeller/formalismer.\"\u003e\r","\t\t\t\t\tcomment = \u003c\"For eksempel lokale informasjonsbehov eller ytterligere metadata for å kunne tilpasse til tilsvarende konsepter i FHIR eller CIMI.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1059\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Klinisk tolkning\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Enkeltord, frase eller kort beskrivelse som representerer den kliniske betydningen og signifikansen av blodtrykksmålingen.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\u003e\r","\t\t\u003e\r","\t\t[\"sv\"] = \u003c\r","\t\t\titems = \u003c\r","\t\t\t\t[\"at0000\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Blodtryck\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Den lokala mätningen av artärblodtrycket som är ett substitut för artärtryck i den systemiska cirkulationen.\"\u003e\r","\t\t\t\t\tcomment = \u003c\"Vanligtvis refererar användningen av termen blodtryck till mätningen av brakialartärtrycket i överarmen.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0001\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Anamnes\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Strukturnod anamnes.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0003\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Tree\"\u003e\r","\t\t\t\t\tdescription = \u003c\"@ internal @\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0004\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Systoliskt\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Det högsta systemiskt arteriella blodtrycket uppmätt systoliskt eller under sammandragningsfasen av hjärtcykeln.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0005\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Diastoliskt\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Det minsta systemiskt arteriella blodtrycket uppmätt diastoliskt eller i hjärtcykelns avslappningsfas.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0006\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Ospecificerad händelse\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Standardval, händelse i ospecificerad tidpunkt eller tidsintervall som explicit kan definieras i en mall eller kan genereras automatiskt av vissa IT-system.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0007\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Tree\"\u003e\r","\t\t\t\t\tdescription = \u003c\"@ internal @\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0008\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Ställning\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Individens kroppsställning under mätningen.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0011\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Träd\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Liststruktur\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0013\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Manschettstorlek\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Storleken på manschetten som används för blodtrycksmätning.\"\u003e\r","\t\t\t\t\tcomment = \u003c\"Perloff D, Grim C, Flack J, Frohlich ED, Hill M, McDonald M, Morgenstern BZ. Human blood pressure determination by sphygmomanometry. Circulation 1993;88;2460-2470.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0014\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Mätplats\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Beskrivning av anatomiskt plats där blodtrycket mäts.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0015\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Vuxet lår\"\u003e\r","\t\t\t\t\tdescription = \u003c\"En lårmanschett för vuxna.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0016\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Stor vuxen\"\u003e\r","\t\t\t\t\tdescription = \u003c\"En manschett för vuxna med större armar.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0017\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Vuxen\"\u003e\r","\t\t\t\t\tdescription = \u003c\"En standardmanschett för vuxna.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0025\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Höger arm\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Individens högra arm.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0026\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Vänster arm\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Individens vänstra arm.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0027\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Höger lår\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Individens högra lår.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0028\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Vänster lår\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Individens vänstra lår.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0033\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Kommentar\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Ytterligare beskrivning av mätningen som inte beskrivits i andra fält.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1000\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Stående\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Stående ställning under blodtrycksmätningen\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1001\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Sittande\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Sittande ställning under blodtrycksmätningen, exempelvis på en säng eller stol.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1002\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Halvliggande\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Halvliggande ställning under blodtrycksmätningen.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1003\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Liggande\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Liggande ställning under blodtrycksmätningen.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1005\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Lutning\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Lutning på ytan av huvuddelen som personen ligger på vid tidpunkten för mätningen.\"\u003e\r","\t\t\t\t\tcomment = \u003c\"OBS: '°' är en giltig UCUM-enhet. Använd \\\"deg\\\" som den rätta enheten.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1006\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Medelartärtryck\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Det genomsnittliga artärtrycket som inträffar under hela hjärtsammandragningen och under avslappningscykeln.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1007\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Pulstryck\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Skillnaden mellan systoliskt och diastoliskt blodtryck.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1008\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Liten Vuxen\"\u003e\r","\t\t\t\t\tdescription = \u003c\"En manschett som används till små vuxna.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1009\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Pediatrisk/Barn\"\u003e\r","\t\t\t\t\tdescription = \u003c\"En manschett som passar barn eller vuxna med smala armar.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1010\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Diastoliskt effektmått\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Registrerat Korotkoff-ljud som används för att avgöra diastoliskt tryck med hjälp av auskultatorisk metod.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1011\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Fas IV\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Det fjärde Korotkoff-ljudet identifieras som en plötslig ljuddämpning.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1012\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Fas V\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Det femte Korotkoff-ljudet identifieras genom avsaknad av ljud då manschettrycket sjunker under det diastoliska blodtrycket.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1014\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Liggande med lutning till vänster\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Liggande i platt ställning med viss lateral lutning, vanligtvis mot vänster sida. Den krävs vanligtvis i graviditetens sista trimester för att lindra aortokaval kompression.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1018\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Spädbarn\"\u003e\r","\t\t\t\t\tdescription = \u003c\"En manschett för spädbarn.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1019\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Nyfödd\"\u003e\r","\t\t\t\t\tdescription = \u003c\"En manschett som används på nyfödda, om manschetten anses vara av lämplig storlek till den nyföddas mognads- och födelsevikt.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1020\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Höger handled\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Individens högra handled.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1021\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Vänster handled\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Individens vänstra handled.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1025\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Utrustning\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Detaljer om blodtrycksmätaren eller annan apparat som används för att mäta blodtrycket.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1026\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Höger vrist\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Individens högra vrist.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1030\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Ansträngning\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Detaljer om den fysiska aktiviteten som utförts vid tidpunkten av blodtrycksmätningen.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1031\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Vänster vrist\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Individens vänstra vrist.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1032\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Finger\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Individens finger.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1035\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Metod\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Metod för mätning av blodtryck.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1036\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Auskultation\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Metod för extern mätning av blodtryck med hjälp av stetoskop och Korotkoff-ljud.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1037\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Palpation\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Metod för att mäta blodtrycket externt med hjälp av palpation, vanligtvis av brakiala eller radiella artärer.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1038\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Formel för medelartärtryck\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Formel som används för att beräkna medelartärtrycket (om det finns registrerat).\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1039\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Blodtrycksmaskin\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Metod för mätning av blodtryck externt med hjälp av en blodtrycksmaskin.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1040\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Invasiv\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Metod för att mäta blodtrycket intravenöst dvs. genom att penetrera huden och mäta inuti blodkärlen.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1042\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"24 timmars blodtrycksmätning\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Beräkning av det genomsnittliga blodtrycket under en 24-timmarsperiod.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1043\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Vakenhet\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Vakenhet som stöder tolkningen av 24-timmars ambulatoriska blodtrycksmätningar.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1044\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Alert och vaken\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Patienten är vid fullt medvetande.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1045\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Sover\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Patienten är i det naturliga tillståndet av kroppslig vila.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1051\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Tå\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Individens tå.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1052\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Möjliga felkällor\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Andra faktorer som kan påverka blodtrycksmätningen, exempelvis ångestnivå, \\\"vitrockseffekt\\\", smärta, feber eller förändringar i lufttryck mm.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1053\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Intraarteriell\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Invasiv mätning via transduktoråtkomstlinjen inom en artär.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1054\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Formel för systoliskt tryck\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Formel som används för att beräkna det systoliska trycket från medelartärtrycket (om det finns registrerat).\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1055\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Formel för diastoliskt tryck\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Formel som används för att beräkna det diastoliska trycket från medelartärtrycket (om det finns registrerat).\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1056\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Fotryggen\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Individens fotrygg.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1057\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Strukturerad mätplats\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Strukturerad anatomisk plats där mätningen gjordes.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1058\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Extra information\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Ytterligare information som krävs för att fånga lokal kontext eller för anpassning till andra referensmodeller och formalismer.\"\u003e\r","\t\t\t\t\tcomment = \u003c\"Exempelvis uppgifter om en lokal sjukhusavdelning eller ytterligare metadata för anpassning till FHIR- eller CIMI-motsvarigheter.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1059\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Klinisk tolkning\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Ord, fras eller kort beskrivning som representerar den kliniska betydelsen och signifikansen av blodtrycksmätningen.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\u003e\r","\t\t\u003e\r","\t\t[\"fi\"] = \u003c\r","\t\t\titems = \u003c\r","\t\t\t\t[\"at0000\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Verenpaine\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Paikallisen valtimopaineen mittaustulos, joka toimii korvikkeena systeemisen verenkierron valtimopaineelle. Termillä \\\"verenpaine\\\" viitataan yleensä olkavarresta tehtävään olkavarsivaltimon paineen mittaustulokseen.\"\u003e\r","\t\t\t\t\tcomment = \u003c\"Yleisimmin termi \\\"verenpaine\\\" viittaa olkavarsivaltimon paineen mittaamiseen yläraajasta.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0001\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Historia\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Historia-rakennesolmu.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0003\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"blood pressure\"\u003e\r","\t\t\t\t\tdescription = \u003c\"@ internal @\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0004\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Systolinen\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Systeemisen verenkierron valtimoverenpaineen huippuarvo – mitataan sydämen supistumisvaiheessa.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0005\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Diastolinen\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Systeemisen verenkierron valtimoverenpaineen pienin arvo – mitataan sydämen lepovaiheessa.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0006\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Mikä tahansa tapahtuma\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Oletusarvo, määrittämätön ajanhetki tai aikaväli, joka voidaan nimenomaisesti määritellä templaatilla tai suorituksen aikana.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0007\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"state structure\"\u003e\r","\t\t\t\t\tdescription = \u003c\"@ internal @\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0008\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Asento\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Henkilön asento mittaushetkellä.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0011\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Puu\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Luettelon rakenne.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0013\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Mansetin koko\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Verenpaineen mittauksessa käytetyn mansetin koko.\"\u003e\r","\t\t\t\t\tcomment = \u003c\"Perloff D, Grim C, Flack J, Frohlich ED, Hill M, McDonald M, Morgenstern BZ. Human blood pressure determination by sphygmomanometry. Circulation 1993;88;2460-2470.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0014\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Mittauskohta\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Kehon yksinkertaisesti ilmaistu kohta, josta verenpaine mitattiin.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0015\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Aikuisen reisi\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Aikuisen reidessä käytettävä mansetti.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0016\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Aikuiset, suuri\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Mansetti aikuisille, joilla on paksut käsivarret.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0017\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Aikuinen\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Standardikokoinen mansetti aikuisille.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0025\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Oikea käsivarsi\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Henkilön oikea käsivarsi.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0026\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Vasen käsivarsi\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Henkilön vasen käsivarsi.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0027\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Oikea reisi\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Henkilön oikea reisi.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0028\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Vasen reisi\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Henkilön vasen reisi.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0033\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Kommentti\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Mittauksen kertomusmuodossa olevat lisätiedot, joita ei voida ilmoittaa muissa kentissä.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1000\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Seisten\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Verenpaine mitataan henkilön seistessä.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1001\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Istuen\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Verenpaine mitataan henkilön istuessa (esimerkiksi vuoteella tai tuolissa).\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1002\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Taaksepäin nojaten\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Verenpaine mitataan henkilön nojatessa taaksepäin.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1003\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Makuulla\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Verenpaine mitataan henkilön maatessa.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1005\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Kallistuma\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Kraniokaudaalinen kallistuma alustalla, jolla henkilö makaa mittauksen aikana.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1006\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Keskivaltimopaine\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Keskiarvo valtimopaineesta, joka ilmenee sydämen supistumis- ja rentoutumissyklin aikana.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1007\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Pulssipaine\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Systolisen ja diastolisen paineen erotus.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1008\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Aikuiset, pieni\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Pienikokoiselle aikuiselle käytettävä mansetti.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1009\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Pediatrinen/lapsi\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Mansetti, joka sopii lapselle tai ohutkäsivartiselle aikuiselle.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1010\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Diastolinen päätetapahtuma\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Tieto siitä, minkä Korotkoffin äänen perusteella diastolinen paine määritetään auskultoitaessa.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1011\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Vaihe IV\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Neljäs Korotkoffin ääni määrittään äänien äkilliseksi heikkenemiseksi.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1012\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Vaihe V\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Viides Korotkoffin ääni määritetään äänien kuulumisen lakkaamiseksi, kun mansetin paine laskee diastolisen verenpaineen alapuolelle.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1014\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Makuulla vasemmalle kallellaan\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Makuulla, hiukan kallellaan kyljen suunnassa, yleensä vasemmalle. Tarvitaan yleensä viimeisellä raskauskolmanneksella supiinioireyhtymän helpottamiseksi.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1018\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Vauva\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Vauvoille käytettävä mansetti.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1019\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Vastasyntynyt\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Vastasyntyneille käytettävä mansetti, mikäli mansetti on oikean kokoinen vastasyntyneen kokoon ja kehitystasoon nähden.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1020\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Oikea ranne\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Tutkittavan oikea ranne.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1021\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Vasen ranne\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Tutkittavan vasen ranne.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1025\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Laite\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Tiedot sfygmomanometrista tai muusta laitteesta, jolla verenpaine mitataan.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1026\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Oikea nilkka\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Tutkittavan oikea nilkka.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1030\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Rasitus\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Tiedot fyysisestä rasituksesta, jolle tutkittava altistettiin verenpaineen mittauksen aikana.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1031\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Vasen nilkka\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Tutkittavan vasen nilkka.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1032\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Sormi\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Tutkittavan sormi.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1035\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Menetelmä\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Verenpaineen mittausmenetelmä.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1036\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Auskultaatio\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Menetelmä, jolla verenpaine mitataan ulkoisesti käyttämällä stetoskooppia ja Korotkoffin ääniä.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1037\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Palpaatio\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Menetelmä, jolla verenpaine mitataan ulkoisesti palpoimalla (yleensä olkavarsi- tai värttinävaltimosta).\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1038\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Keskivaltimopaineen kaava\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Keskivaltimopaineen laskennassa käytettävä kaava (jos kirjattu tietoihin).\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1039\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Kone\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Menetelmä, jolla verenpaine mitataan ulkoisesti koneella.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1040\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Invasiivinen\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Menetelmä, jolla verenpaine mitataan sisäisesti, eli ihon läpi tunkeutuen ja verisuonen sisältä.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1042\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"24 tunnin keskiarvo\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Arvio verenpaineen keskiarvosta 24 tunnin ajanjaksona.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1043\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Unitila\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Unitila – tukee 24 tunnin ambulatorisen verenpainemittauksen tulosten tulkintaa.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1044\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Valpas ja hereillä\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Tutkittava on täysin tajuissaan.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1045\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Nukkuu\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Tutkittavan keho on luonnollisessa lepotilassa.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1051\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Varvas\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Tutkittavan varvas.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1052\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Sekoittavat tekijät\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Kommentoi ja kirjaa muita satunnaistekijöitä, jotka saattavat vaikuttaa verenpaineen mittaukseen. Esimerkiksi ahdistuneisuus tai \\\"valkotakkiverenpaine\\\", kipu tai kuume; ilmanpaineen muutokset, jne.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1053\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Valtimonsisäinen\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Invasiivinen mittaus valtimoon sijoitetulla katetrinpääanturilla.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1054\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Systolisen paineen kaava\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Kaava jota käytetään systolisen paineen laskemiseen keskivaltimopaineesta (jos kirjattu tietoihin).\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1055\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Diastolisen paineen kaava\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Kaava jota käytetään diastolisen paineen laskemiseen keskivaltimopaineesta (jos kirjattu tietoihin).\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1056\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Jalanselkä\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Tutkittavan jalanselkä.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1057\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Rakenteellinen mittauskohta\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Rakenteellinen anatominen kohta, josta mittaus tehtiin.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1058\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Laajennus\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Lisätiedot, joita tarvitaan paikallisen asiayhteyden kirjaamiseksi tai yhtenäistämiseksi muiden viitemallien tai formalismien kanssa.\"\u003e\r","\t\t\t\t\tcomment = \u003c\"Esimerkiksi: Paikallisen sairaalan osaston tiedot tai metatiedot FHIR- tai CIMI-vastineiden mukaisiksi.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1059\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Kliininen tulkinta\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Yksittäinen sana, lause tai lyhyt kuvaus, joka edustaa verenpaineen mittauksen kliinistä merkitystä.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\u003e\r","\t\t\u003e\r","\t\t[\"ca\"] = \u003c\r","\t\t\titems = \u003c\r","\t\t\t\t[\"at0000\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Pressió arterial\"\u003e\r","\t\t\t\t\tdescription = \u003c\"La mesura local de la pressió arterial, que és una substituta de la pressió arterial a la circulació sistèmica.\"\u003e\r","\t\t\t\t\tcomment = \u003c\"Majoritàriament, l'ús del terme «pressió arterial» fa referència a la mesura de la pressió de l'artèria braquial a la part superior del braç.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0001\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Antecedents\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Node estructural dels antecedents.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0003\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"blood pressure\"\u003e\r","\t\t\t\t\tdescription = \u003c\"@ internal @\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0004\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Sistòlica\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Pressió arterial sistemàtica màxima - mesurada en la fase sistòlica o de contracció del cicle cardíac.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0005\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Diastòlica\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Pressió arterial sistemàtica mínima - mesurada en la fase diastòlica o de relaxació del cicle cardíac.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0006\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Qualsevol esdeveniment\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Esdeveniment predeterminat i no especificat d’un moment específic o interval que es pot definir clarament en una plantilla o en temps d’execució.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0007\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"state structure\"\u003e\r","\t\t\t\t\tdescription = \u003c\"@ internal @\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0008\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Posició\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Posició del pacient al moment de la mesura.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0011\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Esquema\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Llistat.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0013\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Grandària del maneguet\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Grandària del maneguet utilitzat per a mesurar la pressió arterial.\"\u003e\r","\t\t\t\t\tcomment = \u003c\"Perloff D, Grim C, Flack J, Frohlich ED, Hill M, McDonald M, Morgenstern BZ. Human blood pressure determination by sphygmomanometry. Circulation 1993;88;2460-2470.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0014\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Zona del mesurament\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Zona del cos on es va mesurar la pressió arterial.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0015\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Cuixa d'un adult\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Maneguet utilitzat per a una cuixa adulta (20 cm x 42 cm aprox.).\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0016\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Adult gran\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Maneguet utilitzat per a un adult amb braços grans (16 cm x 38 cm aprox.).\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0017\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Adult\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Maneguet estàndard per a un adult (13 cm x 30 cm aprox.).\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0025\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Braç dret\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Braç dret del pacient.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0026\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Braç esquerre\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Braç esquerre del pacient.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0027\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Cuixa dreta\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Cuixa dreta del pacient.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0028\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Cuixa esquerra\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Cuixa esquerra del pacient.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0033\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Observacions\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Informació addicional sobre la mesura, no recollida en altres caselles.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1000\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Dret\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Persona de peu al moment de la mesura de la pressió arterial.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1001\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Assegut\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Persona asseguda (per exemple, al llit o en una cadira) al moment de la mesura de la pressió arterial.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1002\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Reclinat\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Persona reclinada al moment de la mesura de la pressió arterial.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1003\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Ajagut\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Persona ajaguda en posició horitzontal al moment de la mesura de la pressió arterial.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1005\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Inclinació\"\u003e\r","\t\t\t\t\tdescription = \u003c\"La inclinació craniocaudal de la superfície on la persona es ajeu al moment de la mesura.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1006\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Pressió arterial mitjana\"\u003e\r","\t\t\t\t\tdescription = \u003c\"La mitjana de la pressió arterial que ocorre durant el cicle complet de contracció i relaxació del cor.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1007\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Pressió de pols\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Diferència entre la pressió sistòlica i la diastòlica.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1008\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Adult petit\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Maneguet utilitzat per a un adult petit (10 cm x 24 cm aprox.).\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1009\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Pediàtric/Infants\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Maneguet apropiat per a un infant o adult amb un braç petit (8 cm x 21 cm aprox.).\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1010\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Punt final diastòlic\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Registra quin so de Korotkoff s'utilitza per a determinar la pressió diastòlica mitjançant el mètode d'auscultació.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1011\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Fase IV\"\u003e\r","\t\t\t\t\tdescription = \u003c\"El quart so Korotkoff s'identifica com un amortiment abrupte de sons.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1012\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Fase V\"\u003e\r","\t\t\t\t\tdescription = \u003c\"El cinquè so de Korotkoff s'identifica per l'absència de sons quan la pressió del maneguet cau per sota de la pressió arterial diastòlica.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1014\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Ajagut cap a l'esquerra\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Persona ajaguda amb una certa inclinació lateral, generalment en angle cap al costat esquerre. Es requereix normalment durant l'últim trimestre d'embaràs per alleujar la compressió aortocava.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1018\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Nadó\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Maneguet utilitzat per a nadons (5 cm x 15 cm aprox.).\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1019\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Nounat\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Maneguet utilitzat per nounats, suposant que el maneguet sigui de la mida adequada per a la maduresa i pes del nounat.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1020\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Canell dret\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Canell dret del pacient.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1021\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Canell esquerre\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Canell esquerre del pacient.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1025\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Dispositiu\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Dades sobre el tensiòmetre o altre dispositiu utilitzat per a mesurar la pressió arterial.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1026\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Turmell dret\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Turmell dret del pacient.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1030\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Esforç\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Dades sobre l'activitat física realitzada al moment de la mesura de la pressió arterial.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1031\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Turmell esquerre\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Turmell esquerre del pacient.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1032\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Dit de la mà\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Un dit de la mà del pacient.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1035\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Mètode\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Mètode de la mesura de la pressió arterial.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1036\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Auscultació\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Mètode extern de mesura de la pressió arterial, utilitzant un estetoscopi i sons de Korotkoff.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1037\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Palpació\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Mètode extern de mesura de la pressió arterial, utilitzant la palpació, en general de l'artèria braquial o artèries radials.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1038\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Fórmula de la pressió arterial mitjana\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Fórmula utilitzada per a calcular la Pressió Arterial Mitjana (en cas de registrar aquesta dada).\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1039\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Màquina\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Mètode extern de mesura de la pressió arterial, utilitzant un dispositiu o màquina.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1040\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Invasiu\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Mètode intern de mesura de la pressió arterial que involucra la penetració de la pell i mesurar dins dels vasos sanguinis.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1042\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Mitjana de 24 hores\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Estimació de la pressió arterial mitjana durant un període de 24 hores.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1043\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Estat del son\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Estat del son - ajuda a la interpretació dels registres de la pressió arterial ambulatòria de 24 hores.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1044\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Despert\"\u003e\r","\t\t\t\t\tdescription = \u003c\"La persona es troba totalment conscient.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1045\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Dormit\"\u003e\r","\t\t\t\t\tdescription = \u003c\"La persona es troba en un estat natural de repòs corporal.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1051\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Dit del peu\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Un dit del peu del pacient.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1052\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Factors de confusió\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Comentar i registrar altres factors incidentals que puguin estar afectant a la mesura de la pressió arterial. Per exemple, nivell d'ansietat o «hipertensió de bata blanca»; dolor o febre; canvis en la pressió atmosfèrica, etc.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1053\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Intraarterial\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Mesura invasiva mitjançant un transductor dins d'una artèria.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1054\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Fórmula de pressió sistòlica\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Fórmula utilitzada per a calcular la pressió sistòlica a partir de la pressió arterial mitjana (en cas de registrar aquesta dada).\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1055\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Fórmula de pressió diastòlica\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Fórmula utilitzada per a calcular la pressió diastòlica a partir de la pressió arterial mitjana (en cas de registrar aquesta dada).\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1056\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Dors del peu\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Dors del peu del pacient.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1057\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Zona estructurada del mesurament\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Zona anatòmica estructurada d'on es va prendre el mesurament.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1058\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Extensió\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Informació addicional requerida per a capturar el contingut local o per alinear-se amb altres models/formalismes de referència.\"\u003e\r","\t\t\t\t\tcomment = \u003c\"Per exemple: informació departamental de l'hospital local o metadades addicionals per alinear-se amb equivalents FHIR o CIMI.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1059\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Interpretació clínica\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Una sola paraula, frase o descripció breu que representi el significat clínic i la importància de la mesura de la pressió arterial.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\u003e\r","\t\t\u003e\r","\t\t[\"el\"] = \u003c\r","\t\t\titems = \u003c\r","\t\t\t\t[\"at0000\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Πίεση αίματος\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Η τοπική μέτρηση της αρτηριακής πίεσης που είναι υποκατάστατο της αρτηριακής πίεσης στη συστηματική κυκλοφορία.\"\u003e\r","\t\t\t\t\tcomment = \u003c\"Συνηθέστερα, η χρήση του όρου «αρτηριακή πίεση» αναφέρεται στη μέτρηση της πίεσης της βραχιόνιας αρτηρίας στο άνω μέρος του βραχίονα.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0001\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Ιστορικό\"\u003e\r","\t\t\t\t\tdescription = \u003c\"*History Structural node.(en)\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0003\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"blood pressure\"\u003e\r","\t\t\t\t\tdescription = \u003c\"@ internal @\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0004\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Συστολική\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Μέγιστη συστηματική αρτηριακή πίεση - μετρούμενη σε φάση συστολής ή συστολής του καρδιακού κύκλου.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0005\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Διαστολική\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Ελάχιστη συστηματική αρτηριακή πίεση - μετρούμενη στη διαστολική φάση ή στη φάση χαλάρωσης του καρδιακού κύκλου.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0006\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"*Any event(en)\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Προεπιλεγμένο, απροσδιόριστο χρονικό σημείο ή συμβάν διαστήματος που μπορεί να ορίζεται ρητά σε ένα πρότυπο ή κατά το χρόνο εκτέλεσης.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0007\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"state structure\"\u003e\r","\t\t\t\t\tdescription = \u003c\"@ internal @\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0008\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Θέση\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Η θέση του ατόμου κατά τη στιγμή της μέτρησης.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0011\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Δομή λίστας\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Δομή λίστας.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0013\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Mέγεθος περιβραχιονίου\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Το μέγεθος του περιβραχιονίου που χρησιμοποιείται για τη μέτρηση της αρτηριακής πίεσης.\"\u003e\r","\t\t\t\t\tcomment = \u003c\"Perloff D, Grim C, Flack J, Frohlich ED, Hill M, McDonald M, Morgenstern BZ. Προσδιορισμός της ανθρώπινης αρτηριακής πίεσης με σφυγμομανομετρία. Κυκλοφορία 1993; 88;2460-2470.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0014\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Θέση μέτρησης\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Απλό σημείο του σώματος όπου μετρήθηκε η αρτηριακή πίεση.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0015\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Μηρός ενηλίκων\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Ένα περιβραχιόνιο που χρησιμοποιείται για έναν μηρό ενηλίκων.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0016\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Μεγάλος ενήλικας\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Ένα περιβραχιόνιο για ενήλικες με μεγαλύτερα χέρια.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0017\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Ενήλικας\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Ένα περιβραχιόνιο που είναι στάνταρ για έναν ενήλικα.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0025\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Δεξιός βραχίωνας\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Το δεξί χέρι του ατόμου.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0026\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Αριστερός βραχίωνας\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Ο αριστερός βραχίονας του ατόμου.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0027\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Δεξιός μηρός\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Ο δεξιός μηρός του ατόμου.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0028\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Αριστερός μηρός\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Ο αριστερός μηρός του ατόμου.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at0033\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Σχόλιο\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Πρόσθετη αφήγηση σχετικά με τη μέτρηση, που δεν αποτυπώνεται σε άλλα πεδία.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1000\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Ορθοστασία\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Στέκεται κατά τη στιγμή της μέτρησης της αρτηριακής πίεσης.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1001\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Καθιστή θέση\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Καθιστή θέση (για παράδειγμα στο κρεβάτι ή την καρέκλα) κατά τη στιγμή της μέτρησης της αρτηριακής πίεσης.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1002\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Ανακλινομενη θέση\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Ανάκλιση κατά τη στιγμή της μέτρησης της αρτηριακής πίεσης.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1003\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Ξαπλωμένη θέση\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Ξαπλωμένη κατά τη στιγμή της μέτρησης της αρτηριακής πίεσης.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1005\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Σε κλίση\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Η κρανιοουραία κλίση της επιφάνειας στην οποία βρίσκεται το άτομο κατά τη στιγμή της μέτρησης.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1006\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Μέση αρτηριακή πίεση\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Η μέση αρτηριακή πίεση που εμφανίζεται καθ 'όλη τη διάρκεια του κύκλου συστολής και χαλάρωσης της καρδιάς.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1007\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Παλμική πίεση\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Η διαφορά μεταξύ της συστολικής και της διαστολικής πίεσης.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1008\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Μικρός ενήλικας\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Ένα περιβραχιόνιο που χρησιμοποιείται για έναν μικρό ενήλικα.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1009\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Παιδικό\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Ένα περιβραχιόνιο που είναι κατάλληλη για παιδί ή ενήλικα με λεπτό χέρι.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1010\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Διαστολικό καταληκτικό σημείο\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Καταγράψτε ποιος ήχος Korotkoff χρησιμοποιείται για τον προσδιορισμό της διαστολικής πίεσης χρησιμοποιώντας ακουστική μέθοδο.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1011\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Phase IV\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Ο τέταρτος ήχος Korotkoff αναγνωρίζεται ως ένα απότομο σιγαστήρα ήχων.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1012\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Phase V\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Ο πέμπτος ήχος Korotkoff αναγνωρίζεται από την απουσία ήχων καθώς η πίεση της μανσέτας πέφτει κάτω από τη διαστολική αρτηριακή πίεση.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1014\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Ξαπλωμένη με κλίση προς τα αριστερά\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Ξαπλωμένη επίπεδη με κάποια πλευρική κλίση, συνήθως υπό γωνία προς την αριστερή πλευρά. Συνήθως απαιτείται στο τελευταίο τρίμηνο της εγκυμοσύνης για την ανακούφιση της συμπίεσης της αορτοκαβάλης.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1018\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Βρέφη\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Ένα περιβραχιόνιο για βρέφη\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1019\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Νεογνά\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Ένα περιβραχιόνιο που χρησιμοποιείται για νεογνά\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1020\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Δεξιός καρπός\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Ο δεξιός καρπός του ατόμου.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1021\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Αριστερός καρπός\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Ο αριστερός καρπός του ατόμου.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1025\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Συσκευή\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Λεπτομέρειες σχετικά με το σφυγμομανόμετρο ή άλλη συσκευή που χρησιμοποιείται για τη μέτρηση της αρτηριακής πίεσης.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1026\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Δεξιός αστράγαλος\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Ο δεξιός αστράγαλος του ατόμου.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1030\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"*Exertion(en)\"\u003e\r","\t\t\t\t\tdescription = \u003c\"*Details about physical activity undertaken at the time of blood pressure measurement.(en)\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1031\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Αριστερός αστράγαλος\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Ο αριστερός αστράγαλος του ατόμου.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1032\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Δάχτυλο\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Ένα δάχτυλο του ατόμου.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1035\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Μέθοδος\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Μέθοδος μέτρησης της αρτηριακής πίεσης.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1036\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Ακρόαση\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Μέθοδος μέτρησης της αρτηριακής πίεσης εξωτερικά, χρησιμοποιώντας στηθοσκόπιο και ήχους Korotkoff\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1037\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Ψηλάφιση\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Μέθοδος μέτρησης της αρτηριακής πίεσης εξωτερικά, χρησιμοποιώντας ψηλάφηση (συνήθως των βραχιονίων ή ακτινωτών αρτηριών).\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1038\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Τύπος μέσης αρτηριακής πίεσης\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Τύπος που χρησιμοποιείται για τον υπολογισμό της μέσης αρτηριακής πίεσης (εάν καταγράφεται στα δεδομένα).\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1039\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Μηχανή\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Μέθοδος μέτρησης της αρτηριακής πίεσης εξωτερικά, χρησιμοποιώντας μια μηχανή αρτηριακής πίεσης.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1040\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Επεμβατική\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Μέθοδος μέτρησης της αρτηριακής πίεσης εσωτερικά, δηλαδή περιλαμβάνει διείσδυση του δέρματος και μέτρηση μέσα στα αιμοφόρα αγγεία.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1042\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"24ωρος μέσος όρος\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Εκτίμηση της μέσης αρτηριακής πίεσης σε μια περίοδο 24 ωρών.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1043\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Κατάσταση ύπνου\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Κατάσταση ύπνου - υποστηρίζει την ερμηνεία των 24ωρων περιπατητικών αρχείων αρτηριακής πίεσης\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1044\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Ξύπνια\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Το άτομο έχει πλήρη συνείδηση.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1045\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Aνάπαυσης\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Το άτομο βρίσκεται στη φυσική κατάσταση της σωματικής ανάπαυσης.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1051\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Δάχτυλο ποδιού\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Ένα δάχτυλο του ατόμου.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1052\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Συγχυτικοί παράγοντες\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Σχολιάστε και καταγράψτε άλλους τυχαίους παράγοντες που μπορεί να συμβάλλουν στη μέτρηση της αρτηριακής πίεσης. Για παράδειγμα, επίπεδο άγχους ή «σύνδρομο λευκού τριχώματος». πόνος ή πυρετός. αλλαγές στην ατμοσφαιρική πίεση κ. λπ.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1053\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Ενδοαρτηριακή\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Επεμβατική μέτρηση μέσω γραμμής πρόσβασης μορφοτροπέα εντός μιας αρτηρίας.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1054\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Τύπος συστολικής πίεσης\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Τύπος που χρησιμοποιείται για τον υπολογισμό της συστολικής πίεσης από τη μέση αρτηριακή πίεση (εάν καταγράφεται στα δεδομένα).\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1055\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Τύπος διαστολικής πίεσης\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Τύπος που χρησιμοποιείται για τον υπολογισμό της διαστολικής πίεσης από τη μέση αρτηριακή πίεση (εάν καταγράφεται στα δεδομένα).\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1056\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Ράχη ποδιού\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Η ράχη του ατόμου του ποδιού.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1057\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Δομημένη τοποθεσία μέτρησης\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Δομημένη ανατομική θέση του σημείου όπου έγινε η μέτρηση.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1058\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"*Extension(en)\"\u003e\r","\t\t\t\t\tdescription = \u003c\"*Additional information required to capture local context or to align with other reference models/formalisms.(en)\"\u003e\r","\t\t\t\t\tcomment = \u003c\"*For example: Local hospital departmental infomation or additional metadata to align with FHIR or CIMI equivalents.(en)\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\t[\"at1059\"] = \u003c\r","\t\t\t\t\ttext = \u003c\"Κλινική ερμηνεία\"\u003e\r","\t\t\t\t\tdescription = \u003c\"Μία λέξη, φράση ή σύντομη περιγραφή που αντιπροσωπεύει την κλινική έννοια και σημασία της μέτρησης της αρτηριακής πίεσης.\"\u003e\r","\t\t\t\t\u003e\r","\t\t\t\u003e\r","\t\t\u003e\r","\t\u003e\r","\tterm_bindings = \u003c\r"