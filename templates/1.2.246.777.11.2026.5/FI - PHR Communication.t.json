ails\" : { }","      },","      \"zh-cn\" : {","        \"@type\" : \"RESOURCE_DESCRIPTION_ITEM\",","        \"language\" : {","          \"terminologyId\" : {","            \"value\" : \"ISO_639-1\"","          },","          \"codeString\" : \"zh-cn\"","        },","        \"purpose\" : \"针对个人所提供信息的容器，用于支持将患者产生型健康数据（patient generated health data，PGHD）与临床医务人员/临床医生产生型健康数据（clinician-generated health data，CGHD）明确地区分/分离开来。\",","        \"keywords\" : [ \"问卷, 调查问卷, 自行报告, 自我报告, 表单, 表格, 调查, PROM, 患者报告型结局指标, 患者报告型效果指标, PREM, 患者报告型体验指标, PRO, 患者报告型效果, 日记, 日志\" ],","        \"use\" : \"作为通用的容器，用来记录个人所提供的信息，以支持将患者产生型健康数据与临床医务人员/临床医生产生型健康数据明确地区分/分离开来。\\r\\n\\r\\n本原始型的内容范围可能非常广泛，并且可以包容很多的上下文背景/语境。预期的内容范围包括但不仅限于：\\r\\n- 自行生成的对于问卷的回答，包括 PREM（Patient-Reported Experience Measure，患者报告型体验指标） 或 PROM（Patient‐Reported Outcome Measure，患者报告型结局/效果指标）\\r\\n- 疼痛或情绪日记\\r\\n- 吸烟日记\\r\\n- 自行生成的健康摘要，用于与他人共享\\r\\n- 对于种种观测项目和观察项目的自行监控/监测\\r\\n\\r\\n本原始型的预期用途包括但不仅限于：\\r\\n- 在已经计划的联系/接触之前，向临床医务人员/临床医生提交自行报告的问卷\\r\\n- 提交联系申请表\\r\\n- 个人健康档案（Personal Health Record，PHR）之中的日常观测结果\\r\\n- 患者在共享型临床门户当中所输入的数据\\r\\n- 患者生成的赋予来自个人或医疗设备的信息的记录\\r\\n\\r\\n在此故意对其总的章节/内容（Sections/Content）构成要素不加约束。这样，在模板当中，就可以利用任何适合相应临床目的的章节型（SECTION）或条目型（ENTRY）原始型来对其加以填充。\",","        \"misuse\" : \"并非旨在用于表达临床医务人员/临床医生产生型的记录。\",","        \"originalResourceUri\" : { },","        \"otherDetails\" : { }","      }","    }","  },","  \"parentArchetypeId\" : \"openEHR-EHR-COMPOSITION.self_reported_data.v1\",","  \"differential\" : true,","  \"archetypeId\" : {","    \"@type\" : \"ARCHETYPE_HRID\",","    \"value\" : \"openEHR-EHR-COMPOSITION.t_self_reported_data.v1\"","  },","  \"definition\" : {","    \"@type\" : \"C_COMPLEX_OBJECT\",","    \"rmTypeName\" : \"COMPOSITION\",","    \"nodeId\" : \"at0000.1\",","    \"attributes\" : [ {","      \"@type\" : \"C_ATTRIBUTE\",","      \"rmAttributeName\" : \"context\",","      \"children\" : [ {","        \"@type\" : \"C_COMPLEX_OBJECT\",","        \"rmTypeName\" : \"EVENT_CONTEXT\",","        \