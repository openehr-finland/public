ss=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003eNot to be used to record capability and means for exchanging information with an individual - use CLUSTER.communication for this purpose.\u003cspan class=\"pl-cce\"\u003e\\r\\n\\r\\n\u003c/span\u003eNot to be used to record details about a request for interpreter services - use CLUSTER.Interpreter_requirements with a suitable INSTRUCTION archetype, for example INSTRUCTION.service_request.\u003cspan class=\"pl-cce\"\u003e\\r\\n\\r\\n\u003c/span\u003eNot to be used to record details about an interpretation that was performed - use the proposed ACTION.interpretation.\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","          \u003cspan class=\"pl-ent\"\u003e\u0026quot;copyright\u0026quot;\u003c/span\u003e : \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e© Nasjonal IKT HF, openEHR Foundation\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","          \u003cspan class=\"pl-ent\"\u003e\u0026quot;originalResourceUri\u0026quot;\u003c/span\u003e : { },","          \u003cspan class=\"pl-ent\"\u003e\u0026quot;otherDetails\u0026quot;\u003c/span\u003e : { }","        },","        \u003cspan class=\"pl-ent\"\u003e\u0026quot;zh-cn\u0026quot;\u003c/span\u003e : {","          \u003cspan class=\"pl-ent\"\u003e\u0026quot;@type\u0026quot;\u003c/span\u003e : \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003eRESOURCE_DESCRIPTION_ITEM\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","          \u003cspan class=\"pl-ent\"\u003e\u0026quot;language\u0026quot;\u003c/span\u003e : {","            \u003cspan class=\"pl-ent\"\u003e\u0026quot;terminologyId\u0026quot;\u003c/span\u003e : {","              \u003cspan class=\"pl-ent\"\u003e\u0026quot;value\u0026quot;\u003c/span\u003e : \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003eI